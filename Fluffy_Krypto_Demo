<!DOCTYPE html>
<html lang="no">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<title>fluffy-krypto-guide – 8x8 LED XOR Demo</title>
<style>
  :root{
    --bg:#0a1a2f;
    --panel:#0f1724;
    --muted:#9aa7b3;
    --hvl-green:#00ff9d;
    --hvl-cyan:#00b4d8;
    --hvl-orange:#ff6f00;
    --white:#ffffff;
    --yellow:#ffff66;
  }

  html,body{height:100%;margin:0;}
  body{
    font-family: "Segoe UI", Arial, sans-serif;
    background: linear-gradient(180deg,var(--bg),#071022 120%);
    color:var(--muted);
    display:flex;
    justify-content:center;
    padding:28px;
  }

  .container{
    width:100%;
    max-width:920px;
    background:linear-gradient(180deg, rgba(255,255,255,0.02), rgba(0,0,0,0.02));
    border-radius:12px;
    padding:20px;
    box-shadow: 0 8px 30px rgba(0,0,0,0.6);
    border: 1px solid rgba(255,255,255,0.03);
  }

  h1{
    margin:0 0 6px 0;
    color:var(--hvl-green);
    font-size:20px;
    letter-spacing:0.6px;
  }
  p.lead{margin:0 0 14px 0;color:#b9c7d4;font-size:13px;}

  .row{display:flex;gap:16px;align-items:flex-start;flex-wrap:wrap;}
  .col{flex:1;min-width:260px;}

  label{display:block;font-size:13px;color:#9fb0c2;margin-top:10px;}
  select,input,button{
    width:100%;
    padding:10px 12px;
    margin-top:6px;
    border-radius:8px;
    border:1px solid rgba(255,255,255,0.04);
    background:linear-gradient(180deg, rgba(255,255,255,0.01), rgba(0,0,0,0.02));
    color:var(--white);
    font-size:14px;
    box-shadow: inset 0 1px 0 rgba(255,255,255,0.02);
  }

  button.primary{
    background: linear-gradient(90deg,var(--hvl-green),#00e68a);
    color:#00110a;
    font-weight:700;
    border:none;
    cursor:pointer;
    margin-top:12px;
  }
  button.ghost{
    background:transparent;
    border:1px solid rgba(255,255,255,0.04);
    color:var(--muted);
    cursor:pointer;
    margin-top:12px;
  }

  .bitbox{
    display:flex;
    gap:8px;
    margin-top:12px;
    font-family: "Courier New", monospace;
  }
  .bit{
    width:34px;height:34px;border-radius:6px;
    display:flex;align-items:center;justify-content:center;
    background:#0f1724;border:1px solid rgba(255,255,255,0.03);
    color:var(--muted);font-weight:700;
    transition: all 160ms ease;
    box-shadow: 0 2px 6px rgba(0,0,0,0.6) inset;
  }
  .bit.flash{
    transform: translateY(-4px);
    color:#00110a;
    background:var(--hvl-green);
    box-shadow: 0 0 18px rgba(0,255,157,0.25);
  }

  /* Matrix */
  .matrix-wrap{margin-top:18px;display:flex;gap:18px;align-items:flex-start;flex-wrap:wrap;}
  .matrix{
    display:grid;
    grid-template-columns: repeat(8, 34px);
    grid-template-rows: repeat(8, 34px);
    gap:6px;
    padding:12px;
    background: linear-gradient(180deg, rgba(255,255,255,0.01), rgba(0,0,0,0.03));
    border-radius:10px;
    border:1px solid rgba(255,255,255,0.03);
  }
  .cell{
    width:34px;height:34px;border-radius:6px;
    background:#071022;border:1px solid rgba(255,255,255,0.02);
    transition: background 180ms ease, box-shadow 180ms ease, transform 120ms ease;
    box-shadow: inset 0 1px 0 rgba(255,255,255,0.02);
  }

  /* marker default (white) and blink (yellow) */
  .cell.marker{
    background:var(--white);
    box-shadow: 0 0 12px rgba(255,255,255,0.12), 0 2px 8px rgba(0,0,0,0.6) inset;
  }
  .cell.marker.blink{
    background:var(--yellow);
    box-shadow: 0 0 18px rgba(255,255,102,0.22), 0 2px 8px rgba(0,0,0,0.6) inset;
    transform: translateY(-2px);
  }

  /* selected marker highlight */
  .cell.selected{
    outline: 2px solid rgba(0,255,157,0.18);
    box-shadow: 0 0 18px rgba(0,255,157,0.12);
    transform: translateY(-3px);
  }

  /* encrypted result highlight (cyan) */
  .cell.result{
    background: var(--hvl-cyan);
    box-shadow: 0 0 18px rgba(0,180,216,0.22);
    transform: translateY(-3px);
    color:#00121a;
  }

  .controls-row{display:flex;gap:12px;align-items:center;margin-top:12px;}
  .small{width:120px;}

  .meta{font-size:12px;color:#8fa6bb;margin-top:10px;}
  footer{margin-top:18px;font-size:12px;color:#6f8aa0;}
  @media (max-width:720px){
    .row{flex-direction:column;}
    .matrix{justify-self:center}
  }
</style>
</head>
<body>
  <div class="container" role="main">
    <h1>fluffy‑krypto‑guide — XOR Demo</h1>
    <p class="lead">Fem tilfeldige markører på en 8×8 LED‑matrise. Velg en markør og en nøkkel, så vises XOR‑krypteringen visuelt.</p>

    <div class="row">
      <div class="col" style="min-width:320px;">
        <label>Velg krypteringsnøkkel</label>
        <select id="keySelect" aria-label="Krypteringsnøkkel">
          <option value="101010">101010</option>
          <option value="011001">011001</option>
          <option value="110100">110100</option>
          <option value="000111">000111</option>
          <option value="111000">111000</option>
          <option value="010101">010101</option>
          <option value="100110">100110</option>
          <option value="001011">001011</option>
        </select>

        <label>Velg en av de 5 markørene</label>
        <select id="markerSelect" aria-label="Marker koordinat"></select>

        <div class="controls-row">
          <button class="primary" id="encryptBtn">Krypter valgt markør</button>
          <button class="ghost" id="regenBtn">Generer nye markører</button>
        </div>

        <div class="meta">Tips: Markerene blinker hvitt/gult. Når du krypterer, vises resultatet som cyan på matrisen.</div>

        <h3 style="color:var(--hvl-cyan);margin-top:18px;font-size:15px;">Bit‑for‑bit XOR</h3>
        <div style="display:flex;gap:8px;align-items:center;flex-wrap:wrap;">
          <div>
            <div style="font-size:12px;color:#9fb0c2;margin-bottom:6px;">Koordinat (6 bit)</div>
            <div id="bitA" class="bitbox"></div>
          </div>
          <div>
            <div style="font-size:12px;color:#9fb0c2;margin-bottom:6px;">Nøkkel (6 bit)</div>
            <div id="bitB" class="bitbox"></div>
          </div>
          <div>
            <div style="font-size:12px;color:#9fb0c2;margin-bottom:6px;">Resultat (6 bit)</div>
            <div id="bitR" class="bitbox"></div>
          </div>
        </div>
      </div>

      <div class="col" style="flex:0 0 360px;">
        <div class="matrix-wrap" aria-hidden="false">
          <div id="matrix" class="matrix" role="grid" aria-label="8x8 LED matrise"></div>
        </div>
      </div>
    </div>

    <footer>Bygg videre: legg til dekryptering, ACK‑meldinger eller WebSocket‑kobling til fysisk hardware.</footer>
  </div>

<script>
/* ---------- Hjelpefunksjoner for UI ---------- */
function el(id){return document.getElementById(id);}
function createBitDiv(bit){ const d=document.createElement('div'); d.className='bit'; d.textContent=bit; return d; }

/* ---------- Matrix og markører ---------- */
const matrixEl = el('matrix');
const markerSelect = el('markerSelect');
const keySelect = el('keySelect');
const encryptBtn = el('encryptBtn');
const regenBtn = el('regenBtn');
const bitAEl = el('bitA');
const bitBEl = el('bitB');
const bitREl = el('bitR');

const ROWS = 8, COLS = 8;
const cells = [];
for(let r=0;r<ROWS;r++){
  cells[r]=[];
  for(let c=0;c<COLS;c++){
    const div=document.createElement('div');
    div.className='cell';
    div.dataset.r=r; div.dataset.c=c;
    matrixEl.appendChild(div);
    cells[r][c]=div;
  }
}

/* Generer 5 unike tilfeldige markører */
let markers = [];
function coordLabelFromRC(r,c){
  const letter = "ABCDEFGH"[r] || '?';
  return `${letter}${c+1}`;
}
function binFromRC(r,c){
  return ((r<<3)|c).toString(2).padStart(6,'0');
}

function generateMarkers(){
  markers = [];
  markerSelect.innerHTML = '';
  while(markers.length < 5){
    const r = Math.floor(Math.random()*ROWS);
    const c = Math.floor(Math.random()*COLS);
    const key = `${r},${c}`;
    if(!markers.includes(key)){
      markers.push(key);
      const bin = binFromRC(r,c);
      const label = `${coordLabelFromRC(r,c)} (${bin})`;
      const opt = document.createElement('option');
      opt.value = bin;
      opt.textContent = label;
      markerSelect.appendChild(opt);
    }
  }
  renderMarkers();
}

/* Render markører på matrisen */
function renderMarkers(){
  // fjern klasser
  for(let r=0;r<ROWS;r++){
    for(let c=0;c<COLS;c++){
      cells[r][c].classList.remove('marker','blink','selected','result');
    }
  }
  markers.forEach(m=>{
    const [r,c] = m.split(',').map(Number);
    cells[r][c].classList.add('marker');
  });
}

/* Blink markører hvitt/gult */
let blinkState = false;
setInterval(()=>{
  blinkState = !blinkState;
  markers.forEach(m=>{
    const [r,c] = m.split(',').map(Number);
    const cell = cells[r][c];
    if(!cell) return;
    if(blinkState){
      cell.classList.add('blink');
      cell.classList.remove('marker');
    } else {
      cell.classList.remove('blink');
      cell.classList.add('marker');
    }
  });
}, 600);

/* Marker valgt markør visuelt */
function highlightSelectedMarker(bin){
  // fjern tidligere selected
  for(let r=0;r<ROWS;r++) for(let c=0;c<COLS;c++) cells[r][c].classList.remove('selected');
  const row = parseInt(bin.slice(0,3),2);
  const col = parseInt(bin.slice(3),2);
  if(cells[row] && cells[row][col]) cells[row][col].classList.add('selected');
}

/* Vis resultat (cyan) midlertidig */
function showResultOnMatrix(bin){
  // fjern tidligere result
  for(let r=0;r<ROWS;r++) for(let c=0;c<COLS;c++) cells[r][c].classList.remove('result');
  const row = parseInt(bin.slice(0,3),2);
  const col = parseInt(bin.slice(3),2);
  if(cells[row] && cells[row][col]) {
    cells[row][col].classList.add('result');
    // vis i 1.2s, så fjern og gjenskape markører
    setTimeout(()=>{ renderMarkers(); highlightSelectedMarker(markerSelect.value); }, 1200);
  }
}

/* ---------- XOR‑logikk og visualisering ---------- */
function renderBits(container, bits){
  container.innerHTML='';
  for(const b of bits){
    container.appendChild(createBitDiv(b));
  }
}

function flashBits(container){
  const bits = Array.from(container.querySelectorAll('.bit'));
  bits.forEach((bit,i)=>{
    setTimeout(()=>bit.classList.add('flash'), i*120);
    setTimeout(()=>bit.classList.remove('flash'), i*120 + 420);
  });
}

/* Hovedfunksjon: krypter valgt markør med valgt nøkkel */
function runXor(){
  const coord = markerSelect.value; // 6-bit
  const key = keySelect.value;      // 6-bit
  if(!coord || !key) return;

  // Vis valgte biter
  renderBits(bitAEl, coord.split(''));
  renderBits(bitBEl, key.split(''));

  // Animasjon: flash input bits
  flashBits(bitAEl);
  setTimeout(()=>flashBits(bitBEl), 200);

  // Beregn XOR
  const result = coord.split('').map((c,i)=> (parseInt(c)^parseInt(key[i])).toString()).join('');

  // Vis resultat etter kort delay
  setTimeout(()=>{
    renderBits(bitREl, result.split(''));
    flashBits(bitREl);
    // Vis resultat på matrisen (cyan)
    showResultOnMatrix(result);
  }, 520);

  // Highlight selected marker under animasjon
  highlightSelectedMarker(coord);
}

/* ---------- Event bindings ---------- */
encryptBtn.addEventListener('click', runXor);
regenBtn.addEventListener('click', ()=>{ generateMarkers(); });

markerSelect.addEventListener('change', ()=>{
  const bin = markerSelect.value;
  highlightSelectedMarker(bin);
  // show bits for quick preview
  renderBits(bitAEl, bin.split(''));
});

/* Init */
generateMarkers();
renderMarkers();
highlightSelectedMarker(markerSelect.value || (markerSelect.options[0] && markerSelect.options[0].value));

/* Accessibility: keyboard support for encryption (Enter) */
document.addEventListener('keydown', (e)=>{
  if(e.key === 'Enter') runXor();
});
</script>
</body>
</html>
